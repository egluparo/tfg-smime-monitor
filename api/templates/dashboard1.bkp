<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard S/MIME Monitor — luparo.com.ar</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <style>
    :root {
      --bg: #0f1117; --surface: #1a1d27; --border: #2a2d3e;
      --accent: #4f8ef7; --green: #22c55e; --red: #ef4444;
      --yellow: #eab308; --text: #e2e8f0; --muted: #6b7280;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', sans-serif; min-height: 100vh; }
    header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 16px 32px; display: flex; align-items: center; gap: 12px; }
    header h1 { font-size: 1.3rem; font-weight: 700; }
    header span { font-size: .85rem; color: var(--muted); }
    .badge { background: var(--accent); color: #fff; padding: 2px 10px; border-radius: 20px; font-size: .75rem; }

    main { padding: 24px 32px; }

    /* Alert banner */
    .alert-banner { background: #422006; border: 1px solid #b45309; border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .alert-banner.hidden { display: none; }
    .alert-banner svg { flex-shrink: 0; }

    /* KPI grid */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 16px; margin-bottom: 28px; }
    .kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .kpi-card .label { font-size: .8rem; color: var(--muted); margin-bottom: 8px; text-transform: uppercase; letter-spacing: .05em; }
    .kpi-card .value { font-size: 2rem; font-weight: 700; }
    .kpi-card .sub { font-size: .8rem; color: var(--muted); margin-top: 4px; }
    .kpi-card.green .value { color: var(--green); }
    .kpi-card.red .value { color: var(--red); }
    .kpi-card.yellow .value { color: var(--yellow); }
    .kpi-card.blue .value { color: var(--accent); }

    /* Charts */
    .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
    .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .chart-card h3 { font-size: .95rem; margin-bottom: 16px; color: var(--muted); }
    canvas { max-height: 220px; }

    /* Table */
    .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; margin-bottom: 28px; }
    .table-card h3 { font-size: .95rem; margin-bottom: 16px; }
    table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    th { background: #12151f; padding: 10px 12px; text-align: left; color: var(--muted); font-weight: 600; border-bottom: 1px solid var(--border); }
    td { padding: 9px 12px; border-bottom: 1px solid #1f2233; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #1f2233; }
    .pill { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: .75rem; font-weight: 600; }
    .pill-green { background: #052e16; color: var(--green); }
    .pill-red   { background: #2d0a0a; color: var(--red); }
    .pill-yellow{ background: #2d2200; color: var(--yellow); }
    .pill-gray  { background: #1f2233; color: var(--muted); }
    .pill-blue  { background: #0a1629; color: var(--accent); }

    .certs-section { background: var(--surface); border: 1px solid #b45309; border-radius: 10px; padding: 20px; }
    .certs-section h3 { font-size: .95rem; margin-bottom: 12px; color: var(--yellow); }

    @media(max-width:700px) {
      .charts-row { grid-template-columns: 1fr; }
      main { padding: 16px; }
    }
  </style>
</head>
<body>
<header>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4f8ef7" stroke-width="2">
    <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
  </svg>
  <h1>Dashboard S/MIME Monitor</h1>
  <span>luparo.com.ar — monitor@luparo.com.ar</span>
  <span class="badge">v2.0</span>
</header>

<main>
  {% if alertas > 0 %}
  <div class="alert-banner">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2">
      <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
      <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <span><strong>Alerta:</strong> {{ alertas }} correo(s) en texto plano recibidos en las últimas 24 horas sin firma ni cifrado.</span>
  </div>
  {% endif %}

  <div class="kpi-grid">
    <div class="kpi-card blue">
      <div class="label">Total Eventos</div>
      <div class="value">{{ total }}</div>
      <div class="sub">correos procesados</div>
    </div>
    <div class="kpi-card green">
      <div class="label">Firmados</div>
      <div class="value">{{ pct_firmados }}%</div>
      <div class="sub">{{ firmados }} de {{ total }}</div>
    </div>
    <div class="kpi-card blue">
      <div class="label">Cifrados</div>
      <div class="value">{{ pct_cifrados }}%</div>
      <div class="sub">{{ cifrados }} de {{ total }}</div>
    </div>
    <div class="kpi-card yellow">
      <div class="label">Texto Plano</div>
      <div class="value">{{ texto_plano }}</div>
      <div class="sub">sin firma ni cifrado</div>
    </div>
    <div class="kpi-card red">
      <div class="label">Errores / Alertas</div>
      <div class="value">{{ errores }}</div>
      <div class="sub">firmas inválidas</div>
    </div>
  </div>

  <div class="charts-row">
    <div class="chart-card">
      <h3>Cumplimiento S/MIME</h3>
      <canvas id="pieChart"></canvas>
    </div>
    <div class="chart-card">
      <h3>Tendencia 7 días</h3>
      <canvas id="lineChart"></canvas>
    </div>
  </div>

  <div class="table-card">
    <h3>Registros Recientes (últimos 20)</h3>
    <table>
      <thead>
        <tr>
          <th>#</th><th>Remitente</th><th>Asunto</th><th>Fecha</th>
          <th>Firmado</th><th>Válido</th><th>Cifrado</th><th>Estado</th>
        </tr>
      </thead>
      <tbody>
        {% for e in eventos %}
        {% set estado = "TEXTO PLANO" %}
        {% if e.cifrado and e.firmado and e.firma_valida %}
          {% set estado = "CIFRADO+FIRMADO" %}
        {% elif e.cifrado %}
          {% set estado = "CIFRADO" %}
        {% elif e.firmado and e.firma_valida %}
          {% set estado = "FIRMADO OK" %}
        {% elif e.firmado %}
          {% set estado = "FIRMA INVÁLIDA" %}
        {% endif %}
        <tr>
          <td>{{ e.id }}</td>
          <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{{ e.remitente or "—" }}</td>
          <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{{ e.subject or "—" }}</td>
          <td style="white-space:nowrap">{{ e.fecha_hora[:16] if e.fecha_hora else "—" }}</td>
          <td>{% if e.firmado %}<span class="pill pill-green">Sí</span>{% else %}<span class="pill pill-gray">No</span>{% endif %}</td>
          <td>{% if e.firma_valida %}<span class="pill pill-green">Sí</span>{% elif e.firmado %}<span class="pill pill-red">No</span>{% else %}<span class="pill pill-gray">—</span>{% endif %}</td>
          <td>{% if e.cifrado %}<span class="pill pill-blue">Sí</span>{% else %}<span class="pill pill-gray">No</span>{% endif %}</td>
          <td>
            {% if estado == "CIFRADO+FIRMADO" %}<span class="pill pill-green">{{ estado }}</span>
            {% elif estado == "CIFRADO" %}<span class="pill pill-blue">{{ estado }}</span>
            {% elif estado == "FIRMADO OK" %}<span class="pill pill-green">{{ estado }}</span>
            {% elif estado == "FIRMA INVÁLIDA" %}<span class="pill pill-red">{{ estado }}</span>
            {% else %}<span class="pill pill-yellow">{{ estado }}</span>{% endif %}
          </td>
        </tr>
        {% else %}
        <tr><td colspan="8" style="text-align:center;color:var(--muted);padding:20px">Sin registros aún.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if certs_por_vencer %}
  <div class="certs-section">
    <h3>⚠ Certificados próximos a vencer (≤30 días)</h3>
    <table>
      <thead><tr><th>CN</th><th>Email</th><th>Vence</th></tr></thead>
      <tbody>
        {% for c in certs_por_vencer %}
        <tr><td>{{ c.sujeto_cn }}</td><td>{{ c.email or "—" }}</td><td>{{ c.vence }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</main>

<script>
const tendencia = {{ tendencia | safe }};

// Pie chart
new Chart(document.getElementById('pieChart'), {
  type: 'doughnut',
  data: {
    labels: ['Firmados', 'Texto plano', 'Cifrados', 'Errores'],
    datasets: [{
      data: [{{ firmados }}, {{ texto_plano }}, {{ cifrados }}, {{ errores }}],
      backgroundColor: ['#22c55e', '#eab308', '#4f8ef7', '#ef4444'],
      borderWidth: 0,
    }]
  },
  options: {
    plugins: { legend: { labels: { color: '#e2e8f0', font: { size: 12 } } } },
    cutout: '65%'
  }
});

// Line chart
const labels = tendencia.map(r => r.dia);
new Chart(document.getElementById('lineChart'), {
  type: 'line',
  data: {
    labels,
    datasets: [
      { label: 'Total', data: tendencia.map(r=>r.total), borderColor:'#6b7280', tension:.4, fill:false },
      { label: 'Firmados', data: tendencia.map(r=>r.firmados||0), borderColor:'#22c55e', tension:.4, fill:false },
      { label: 'Cifrados', data: tendencia.map(r=>r.cifrados||0), borderColor:'#4f8ef7', tension:.4, fill:false },
    ]
  },
  options: {
    plugins: { legend: { labels: { color: '#e2e8f0', font: { size: 11 } } } },
    scales: {
      x: { ticks: { color: '#6b7280' }, grid: { color: '#1f2233' } },
      y: { ticks: { color: '#6b7280' }, grid: { color: '#1f2233' } }
    }
  }
});
</script>
</body>
</html>
